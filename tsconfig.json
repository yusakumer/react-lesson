{
  "compilerOptions": {
    "jsx": "react",
    "sourceMap": true,
    "target": "es6",
    "module": "nodenext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "./src",
    "outDir": "dist",
    "allowJs": true,
    "checkJs": false,
    "moduleResolution": "nodenext",
    "types": [
      "jest",
      "@testing-library/jest-dom",
      "@testing-library/react",
      "node"
    ] // <- 追加
  },
  "include": ["src"]
}

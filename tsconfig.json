{
  "compilerOptions": {
    "jsx": "react",
    "sourceMap": true,
    "target": "es6",
    "module": "esnext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "./src",
    "outDir": "dist",
    "allowJs": true,
    "checkJs": false,
  },
  "include": ["src"]
}
